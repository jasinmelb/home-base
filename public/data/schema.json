{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Home Base Weekly Meal Plan",
  "description": "Weekly meal plan for Jason and Penny, generated by Tubby (AI nutritionist agent)",
  "type": "object",
  "required": ["metadata", "week", "year", "startDate", "endDate", "days"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["week", "startDate", "generatedBy", "generatedAt"],
      "properties": {
        "week": { "type": "integer", "description": "ISO week number" },
        "startDate": { "type": "string", "format": "date", "description": "First day of the meal plan week (YYYY-MM-DD)" },
        "generatedBy": { "type": "string", "description": "Agent that generated the plan (e.g. 'tubby')" },
        "generatedAt": { "type": "string", "format": "date-time", "description": "ISO 8601 timestamp of when the plan was generated" }
      }
    },
    "week": { "type": "integer", "description": "ISO week number" },
    "year": { "type": "integer" },
    "startDate": { "type": "string", "format": "date" },
    "endDate": { "type": "string", "format": "date" },
    "days": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "type": "object",
        "required": ["day", "date", "breakfast", "lunch", "dinner", "snacks", "jasonTotal", "pennyTotal"],
        "properties": {
          "day": { "type": "string", "enum": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"] },
          "date": { "type": "string", "format": "date" },
          "breakfast": { "$ref": "#/$defs/meal" },
          "lunch": { "$ref": "#/$defs/meal" },
          "dinner": { "$ref": "#/$defs/meal" },
          "snacks": { "$ref": "#/$defs/meal" },
          "jasonTotal": { "$ref": "#/$defs/macros" },
          "pennyTotal": { "$ref": "#/$defs/macros" },
          "isDateNight": { "type": "boolean" },
          "dateNightNote": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "macros": {
      "type": "object",
      "required": ["calories", "protein", "carbs", "fat"],
      "properties": {
        "calories": { "type": "number" },
        "protein": { "type": "number" },
        "carbs": { "type": "number" },
        "fat": { "type": "number" }
      }
    },
    "meal": {
      "type": "object",
      "required": ["name", "jason", "penny", "ingredients"],
      "properties": {
        "name": { "type": "string", "description": "Meal name (can include both people's meals separated by /)" },
        "jason": { "$ref": "#/$defs/macros" },
        "penny": { "$ref": "#/$defs/macros" },
        "ingredients": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "amount", "category"],
            "properties": {
              "name": { "type": "string" },
              "amount": { "type": "string" },
              "category": {
                "type": "string",
                "enum": ["Produce", "Meat & Seafood", "Dairy & Eggs", "Pantry", "Frozen", "Bakery", "Drinks", "Spices & Seasonings", "Sauces & Condiments", "Other"]
              }
            }
          }
        },
        "notes": { "type": "string" }
      }
    }
  }
}
